# Copy to `.env` at the repo root. Never commit `.env`.
#
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL=

# Optional overrides for listing tables / source filter (defaults are generic).
# Set these to match your database object names locally.
SALE_TABLE=sale_listings
RENTAL_TABLE=rental_listings
SOURCE_SITE=listing_portal

# Optional: Google Earth Engine Cloud project id (required by newer earthengine-api).
# Register at https://code.earthengine.google.com/register then set:
# EE_PROJECT=your-gcp-project-id
EE_PROJECT=
